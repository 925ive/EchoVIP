            g_ReboundFakePos = V3.New(targetPed.Position.x, targetPed.Position.y, targetPed.Position.z)
            g_ReboundLocalPed = GTA.GetLocalPed()
            if not g_ReboundLocalPed then
                GUI.AddToast("反弹崩溃", "❌ 无法获取本地玩家", 2000, eToastPos.BOTTOM_RIGHT)
                f:SetBoolValue(false)
                return
            end
            g_ReboundRealPos = V3.New(g_ReboundLocalPed.Position.x, g_ReboundLocalPed.Position.y, g_ReboundLocalPed.Position.z)
            g_ReboundActive = true
            g_ReboundTargetId = playerId
            g_ReboundLastUpdateTime = Time.GetEpocheMs()
            Logger.Log(eLogColor.GREEN, "[反弹]", string.format("已开始，跟踪玩家 %d 初始位置 (%.2f, %.2f, %.2f)", playerId, g_ReboundFakePos.x, g_ReboundFakePos.y, g_ReboundFakePos.z))
            Rebound_CreateCameraSafely()
            g_ReboundLoopRunning = true
            g_ReboundLoopJob = Script.QueueJob(Rebound_Loop)
        else
            Rebound_Stop()
        end
    end,
    true
)

