-- ========== EchoVIP 验证系统 ==========
-- 黑名单列表 (RID)
local ECHOVIP_BLACKLIST = {}

local function trim(s)
    return (s and tostring(s):gsub("^%s+", ""):gsub("%s+$", "")) or ""
end

local function verifyPlayer()
    -- 检查是否在线
    if not NETWORK.NETWORK_IS_SESSION_ACTIVE() then
        GUI.AddToast("EchoVIP - 离线模式", "请进入在线模式使用此脚本", 10000, eToastPos.TOP_RIGHT)
        return false
    end
    
    local playerIndex = PLAYER.PLAYER_ID()
    if playerIndex == -1 then
        GUI.AddToast("EchoVIP - 验证失败", "无法获取玩家ID", 10000, eToastPos.TOP_RIGHT)
        return false
    end
    
    local gamerHandle = Memory.Alloc(13 * 8)
    NETWORK.NETWORK_HANDLE_FROM_PLAYER(playerIndex, gamerHandle, 13)
    local memberId = NETWORK.NETWORK_MEMBER_ID_FROM_GAMER_HANDLE(gamerHandle)
    Memory.Free(gamerHandle)
    
    memberId = trim(memberId)
    if memberId == "" or memberId == "**Invalid**" then
        GUI.AddToast("EchoVIP - 验证失败", "无法获取RID", 10000, eToastPos.TOP_RIGHT)
        return false
    end
    
    -- 检查黑名单
    for i = 1, #ECHOVIP_BLACKLIST do
        if trim(ECHOVIP_BLACKLIST[i]) == memberId then
            GUI.AddToast("EchoVIP - 黑名单", "您已被禁止使用此脚本", 10000, eToastPos.TOP_RIGHT)
            return false
        end
    end
    
    return true, playerIndex, memberId
end

