    local pos = targetPed.Position
    local heading = ENTITY.GET_ENTITY_HEADING(GTA.PointerToHandle(targetPed))
    local forward = ENTITY.GET_ENTITY_FORWARD_VECTOR(GTA.PointerToHandle(targetPed))
