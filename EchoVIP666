-- ========== 反弹崩溃（跟踪） ==========
-- 功能：开启后，将本地玩家坐标覆盖到当前选中玩家的位置，并创建一个相机固定在本地玩家原始位置，
--       每0.5秒更新目标位置，实现“反弹”伪装效果。关闭时恢复坐标并销毁相机。
local g_ReboundActive = false
local g_ReboundTargetId = nil
local g_ReboundFakePos = nil
local g_ReboundRealPos = nil
local g_ReboundCamera = nil
local g_ReboundLoopRunning = false
local g_ReboundLoopJob = nil
local g_ReboundCameraCreated = false
local g_ReboundLocalPed = nil
local g_ReboundLastUpdateTime = 0
local NATIVE_CREATE_CAM = 0xC3981DCE61D9E13F
local NATIVE_SET_CAM_COORD = 0x4D41783FB745E42E
local NATIVE_SET_CAM_ROT = 0x85973643155D0B07
local NATIVE_RENDER_SCRIPT_CAMS = 0x07E5B515DB0636FC
local NATIVE_DESTROY_CAM = 0x865908C81A2C22E9
local NATIVE_OVERRIDE_COORDS = 0xA7E30DE9272B6D49

local function Rebound_CreateCameraSafely()
    if g_ReboundCameraCreated or not g_ReboundRealPos then return end
    Script.QueueJob(function()
        g_ReboundCamera = Natives.InvokeInt(NATIVE_CREATE_CAM, "DEFAULT_SCRIPTED_CAMERA", true)
        if g_ReboundCamera and g_ReboundCamera ~= 0 then
            Natives.InvokeVoid(NATIVE_SET_CAM_COORD, g_ReboundCamera, g_ReboundRealPos.x, g_ReboundRealPos.y, g_ReboundRealPos.z)
            local heading = g_ReboundLocalPed.Heading or 0
            Natives.InvokeVoid(NATIVE_SET_CAM_ROT, g_ReboundCamera, 0, 0, heading, 2)
            Natives.InvokeVoid(NATIVE_RENDER_SCRIPT_CAMS, true, true, 0, false, false, 0)
            g_ReboundCameraCreated = true
            Logger.Log(eLogColor.GREEN, "[反弹]", "脚本相机已创建并启用")
        else
            Logger.Log(eLogColor.RED, "[错误]", "创建相机失败")
        end
    end)
end

local function Rebound_Stop()
    if not g_ReboundActive then return end
    g_ReboundActive = false
    g_ReboundLoopRunning = false
    g_ReboundTargetId = nil
    if g_ReboundLocalPed and g_ReboundRealPos then
        g_ReboundLocalPed.Position = g_ReboundRealPos
    end
    if g_ReboundCameraCreated then
        Script.QueueJob(function()
            Natives.InvokeVoid(NATIVE_RENDER_SCRIPT_CAMS, false, true, 0, false, false, 0)
            Natives.InvokeVoid(NATIVE_DESTROY_CAM, g_ReboundCamera, false)
            g_ReboundCameraCreated = false
            g_ReboundCamera = nil
        end)
    end
    g_ReboundFakePos = nil
    if g_ReboundLoopJob then
        g_ReboundLoopJob = nil
    end
    Logger.Log(eLogColor.YELLOW, "[反弹]", "已停止")
end

local function Rebound_Loop()
    while g_ReboundLoopRunning do
        if not g_ReboundActive then break end

        local now = Time.GetEpocheMs()
        if now - g_ReboundLastUpdateTime >= 500 then
            g_ReboundLastUpdateTime = now
            if g_ReboundTargetId then
                local targetPed = Players.GetCPed(g_ReboundTargetId)
                if targetPed then
                    local pos = targetPed.Position
                    if pos then
                        g_ReboundFakePos = V3.New(pos.x, pos.y, pos.z)
                    end
                else
                    Logger.Log(eLogColor.RED, "[警告]", "目标玩家不存在，停止反弹")
                    Rebound_Stop()
                    break
                end
            end
        end

        if g_ReboundFakePos and g_ReboundLocalPed then
            g_ReboundLocalPed.Position = g_ReboundFakePos
            Natives.InvokeVoid(NATIVE_OVERRIDE_COORDS, g_ReboundLocalPed, g_ReboundFakePos.x, g_ReboundFakePos.y, g_ReboundFakePos.z, 0)
            if g_ReboundCameraCreated and g_ReboundCamera then
                Script.QueueJob(function()
                    Natives.InvokeVoid(NATIVE_SET_CAM_COORD, g_ReboundCamera, g_ReboundRealPos.x, g_ReboundRealPos.y, g_ReboundRealPos.z)
                end)
            end
        end

        Script.Yield(50)
    end
end

