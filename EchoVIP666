-- ========== 辅助函数 ==========
function networkRQ(ent)
    local attempts = 0
    while not NETWORK.NETWORK_HAS_CONTROL_OF_ENTITY(ent) and attempts < 50 do
        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(ent)
        Script.Yield(10)
        attempts = attempts + 1
    end
    return NETWORK.NETWORK_HAS_CONTROL_OF_ENTITY(ent)
end

function deleteEnt(ent)
    if not ENTITY.DOES_ENTITY_EXIST(ent) then return end
    local mem = Memory.AllocInt()
    Memory.WriteInt(mem, ent)
    ENTITY.DELETE_ENTITY(mem)
    Memory.Free(mem)
end

function atan2(y, x)
    if x > 0 then return math.atan(y / x)
    elseif x < 0 then
        if y >= 0 then return math.atan(y / x) + math.pi
        else return math.atan(y / x) - math.pi end
    elseif x == 0 then
        if y > 0 then return math.pi / 2
        elseif y < 0 then return -math.pi / 2
        else return 0 end
    end
end

-- ========== 公共碎片生成函数（完全复用原碎片崩溃逻辑） ==========
local function SpawnFragmentsAtPlayer(playerId, count, allEntitiesTable)
    local targetPed = Players.GetCPed(playerId)
    if not targetPed then return {} end
    local pos = targetPed.Position
    local fragModel = Utils.Joaat("prop_fragtest_cnst_04")
    
    STREAMING.REQUEST_MODEL(fragModel)
    local timeout = 0
    while not STREAMING.HAS_MODEL_LOADED(fragModel) and timeout < 200 do
        Script.Yield(15)
        timeout = timeout + 1
    end
    if not STREAMING.HAS_MODEL_LOADED(fragModel) then return {} end
    
    local spawned = {}
    for i = 1, count do
        local obj = GTA.CreateObject(fragModel, pos.x + (math.random() - 0.5) * 3, pos.y + (math.random() - 0.5) * 3, pos.z + math.random(0, 3), true, true)
        if obj and obj ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
            ENTITY.FREEZE_ENTITY_POSITION(obj, false)
            ENTITY.APPLY_FORCE_TO_ENTITY(obj, 1, (math.random() - 0.5) * 10, (math.random() - 0.5) * 10, math.random(1, 5), 0, 0, 0, 1, true, true, true, true, true)
            table.insert(spawned, obj)
            if allEntitiesTable then
                table.insert(allEntitiesTable, obj)
            end
        end
        Script.Yield(10)
    end
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(fragModel)
    return spawned
end

