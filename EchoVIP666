local function getSessionHostByNative()
    local hostId = NETWORK.NETWORK_GET_HOST_PLAYER_INDEX()
    if hostId ~= -1 then
        local name = NETWORK.NETWORK_PLAYER_GET_NAME(hostId)
        if name and name ~= "" then return name end
    end
    return "未知"
end

local function getScriptHostByNative()
    local scriptHostId = NETWORK.NETWORK_GET_HOST_OF_SCRIPT("freemode", -1, 0)
    if scriptHostId ~= -1 then
        local name = NETWORK.NETWORK_PLAYER_GET_NAME(scriptHostId)
        if name and name ~= "" then return name end
    end
    return "未知"
end

local function getPlayerCount()
    return NETWORK.NETWORK_GET_NUM_CONNECTED_PLAYERS()
end

local function getEntityCounts()
    local vehicleCount = PoolMgr.GetCurrentVehicleCount() or 0
    local pedCount = PoolMgr.GetCurrentPedCount() or 0
    local objectCount = PoolMgr.GetCurrentObjectCount() or 0
    return vehicleCount, pedCount, objectCount
end

local function getRainbowColor(offset)
    local time = Time.GetEpocheMs() / 1000
    local r = math.sin(time * 2 + offset) * 0.5 + 0.5
    local g = math.sin(time * 2 + offset + 2.094) * 0.5 + 0.5
    local b = math.sin(time * 2 + offset + 4.188) * 0.5 + 0.5
    return r, g, b
end

local function getGradientColor(offset)
    local time = Time.GetEpocheMs() / 1000
    local r = math.sin(time * 1.5 + offset) * 0.3 + 0.4
    local g = math.sin(time * 1.5 + offset + 1.0) * 0.2 + 0.3
    local b = math.sin(time * 1.5 + offset + 2.0) * 0.3 + 0.7
    return r, g, b
end

local particles = {}
local PARTICLE_COUNT = 20
local FALL_SPEED = 0.5
local UPDATE_INTERVAL = 1/60 * 1000

for i = 1, PARTICLE_COUNT do
    table.insert(particles, {
        x = math.random(), y = math.random(),
        vx = (math.random() - 0.5) * 0.1,
        vy = FALL_SPEED * (0.8 + math.random() * 0.4),
    })
end

local accumulator = 0
local lastTimeMs = Time.GetEpocheMs()

local function updateParticles()
    local nowMs = Time.GetEpocheMs()
    local dt = math.min(nowMs - lastTimeMs, 200)
    lastTimeMs = nowMs
    accumulator = accumulator + dt

    while accumulator >= UPDATE_INTERVAL do
        for _, p in ipairs(particles) do
            p.x = p.x + p.vx * (UPDATE_INTERVAL / 1000)
            p.y = p.y + p.vy * (UPDATE_INTERVAL / 1000)

            if p.y > 1.0 then
                p.y = 0.0
                p.x = math.random()
            end

            if p.x < 0 then p.x = 0; p.vx = -p.vx end
            if p.x > 1 then p.x = 1; p.vx = -p.vx end
        end
        accumulator = accumulator - UPDATE_INTERVAL
    end
end

local function drawWindow()
    updateParticles()

    ImGui.SetNextWindowBgAlpha(0.85)
    ImGui.SetNextWindowPos(100, 100, ImGuiCond.FirstUseEver)
    ImGui.SetNextWindowSize(300, 280, ImGuiCond.FirstUseEver)

    if ImGui.Begin("Echo VIP 战局信息", true, ImGuiWindowFlags.NoCollapse) then
        local r1, g1, b1 = getRainbowColor(0)
        ImGui.TextColored(r1, g1, b1, 1.0, "=== Echo-VIP 公益脚本 ===")
        ImGui.TextColored(r1, g1, b1, 1.0, "     --- 作者 Z ---")
        ImGui.Separator()

        local r2, g2, b2 = getGradientColor(0)
        ImGui.TextColored(r2, g2, b2, 1.0, "[ 战局信息 ]")
        ImGui.Text("战局主机: " .. getSessionHostByNative())
        ImGui.Text("脚本主机: " .. getScriptHostByNative())
        ImGui.Text("玩家数量: " .. getPlayerCount())

        ImGui.Spacing()

        local r3, g3, b3 = getGradientColor(2)
        ImGui.TextColored(r3, g3, b3, 1.0, "[ 实体池 ]")
        local vehicleCount, pedCount, objectCount = getEntityCounts()
        ImGui.Text("载具数量: " .. vehicleCount)
        ImGui.Text("人物数量: " .. pedCount)
        ImGui.Text("物体数量: " .. objectCount)

        ImGui.Spacing()
        ImGui.Separator()

        local r4, g4, b4 = getRainbowColor(3)
        ImGui.TextColored(r4, g4, b4, 1.0, "  公益脚本 纯净体验  ")
    end
    ImGui.End()
    
    -- 绘制 Fear Of SJ 文字（5秒后自动消失，字体放大）
    if echoOm_drawing then
        if Time.GetEpocheMs() < echoOm_drawEndTime then
            local r, g, b = getRainbowColor(0)
            local alpha = math.sin(Time.GetEpocheMs() / 500) * 0.3 + 0.7
            
            HUD.BEGIN_TEXT_COMMAND_DISPLAY_TEXT("STRING")
            HUD.ADD_TEXT_COMPONENT_SUBSTRING_WEBSITE("Fear Of SJ")
            HUD.SET_TEXT_SCALE(7.0, 7.0)  -- 字体放大到7.0
            HUD.SET_TEXT_FONT(4)
            HUD.SET_TEXT_COLOUR(math.floor(r * 255), math.floor(g * 255), math.floor(b * 255), math.floor(alpha * 255))
            HUD.SET_TEXT_WRAP(0.0, 1.0)
            HUD.SET_TEXT_CENTRE(true)
            HUD.END_TEXT_COMMAND_DISPLAY_TEXT(0.5, 0.4, 0)
        else
            echoOm_drawing = false
        end
    end
end

