        FileMgr.GetMenuRootPath() .. "\\Lua\\EchoVIP\\natives.lua",
        FileMgr.GetMenuRootPath() .. "\\Lua\\natives.lua",
        FileMgr.GetMenuRootPath() .. "\\scripts\\natives.lua",
